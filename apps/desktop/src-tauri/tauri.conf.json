{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Gmail AI Manager",
  "version": "0.0.1",
  "identifier": "work.supar.gam",
  "build": {
    "beforeDevCommand": "pnpm --filter @gam/api run dev",
    "beforeBuildCommand": "pnpm -w run build:webapi",
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {}
}
