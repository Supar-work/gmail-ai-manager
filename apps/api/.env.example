# Server
NODE_ENV=development
PORT=3001
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:5173

# SQLite — relative paths are resolved from apps/api
DATABASE_URL=file:./dev.db

# Sessions — 32+ random bytes (openssl rand -hex 32)
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# AES-256-GCM key for token encryption (32 bytes, base64: openssl rand -base64 32)
TOKEN_ENC_KEY=replace-me-with-openssl-rand-base64-32

# Google OAuth — "Desktop app" or "Web app" OAuth client from the GCP console.
# For local use, Google accepts http://127.0.0.1 / http://localhost redirects.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://127.0.0.1:3001/auth/google/callback

# Claude Code CLI — rules are classified by invoking `claude -p` locally.
# Leave CLAUDE_BIN unset if `claude` is already on PATH.
CLAUDE_BIN=claude
# CLAUDE_MODEL=claude-haiku-4-5-20251001
