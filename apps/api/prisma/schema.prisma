generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum or JSON types. Enum columns are stored as strings
// and validated at the app layer; object fields are JSON-stringified.

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  googleSub           String     @unique
  timezone            String     @default("UTC")
  encAccessToken      Bytes?
  encRefreshToken     Bytes?
  tokenScope          String?
  tokenExpiresAt      DateTime?
  watchExpiresAt      DateTime?
  lastHistoryId       String?
  status              String     @default("active") // active | needsReauth | paused
  migratedAt          DateTime?
  pollIntervalSec     Int        @default(120)
  // Null = let Claude Code CLI pick its default. Otherwise a model id like
  // "claude-haiku-4-5-20251001" passed as --model to each `claude -p` call.
  claudeModel         String?
  // Free-form bullet-list of cross-cutting patterns the AI should always
  // consider when proposing or evaluating rules. Examples: "one-time
  // codes → archive after an hour", "calendar invites → keep in inbox
  // until event passes". Null = use the curated default in
  // apps/api/src/claude/ai-guidance.ts. Surfaced in Settings → AI guidance.
  aiGuidance          String?
  // Auto-learned bullet-list distilled by the memory consolidator
  // (apps/api/src/jobs/memory-consolidator.ts) from EmailDecision history,
  // user toggles, and (later) ChatMessages. Merged with `aiGuidance`
  // before being passed to the proposer so the user sees one effective
  // text but keeps the two cleanly separable. Null = no memory yet.
  learnedMemory       String?
  // When the consolidator last ran. Null until the first successful pass.
  learnedMemoryAt     DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  rules               Rule[]
  filterBackups       FilterBackup[]
  decisions           EmailDecision[]
  scheduledActions    ScheduledAction[]
  forwardingAddresses ForwardingAddress[]
  classifyRuns        ClassifyRun[]
  inboxMessages       InboxMessage[]
  gmailFilters        GmailFilter[]
  agentActions        AgentAction[]
  chatThreads         ChatThread[]
  chatMessages        ChatMessage[]
  messageEmbeddings   MessageEmbedding[]
}

// ── Chat surface ────────────────────────────────────────────────────────
// One ChatThread per logical conversation; the chat tab can show a list
// and let the user start new threads. Messages are append-only and
// persist across restarts (one of the things we beat open-poke at).

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  // First-message-derived title; null until we summarise the thread.
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  // "user" | "assistant" | "system" — same shape as Anthropic's messages API
  role      String
  // Plain-text body (assistant turns may be partial; SSE delivers tokens).
  content   String
  // When the message includes tool_use / tool_result blocks, the structured
  // payload lives here as JSON. Frontend renders a collapsible trail.
  toolEventsJson String?
  // Status of an assistant turn. user messages are always 'done'.
  status    String   @default("done")
  // Free-form persona ("coordinator" today; specialists in M6).
  persona   String?
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([userId, createdAt])
}

// One row per Gmail-mutating (or rule/schedule-mutating) tool call.
// Drives the Settings → Audit log UI and the chat surface's "what the
// agent did" trail. Every code path that mutates state is supposed to
// emit a row via `apps/api/src/audit/record.ts`; the chat agent (when
// it lands) hits this through MCP tools.
//
// `reversibleAs` is non-null when the action has a deterministic inverse
// (label add ↔ remove, archive ↔ unarchive). One-click reversal in the
// UI re-applies that inverse and links the original row to the new one
// via `reversedAt` + `reversedBy`.
model AgentAction {
  id             String   @id @default(cuid())
  userId         String
  // What context produced this action.
  source         String   // "rule" | "schedule" | "cleanup" | "chat" | "consolidator"
  sourceId       String?  // ChatMessage.id / Rule.id / ScheduledAction.id / etc
  // What the agent touched.
  targetType     String   // "gmailMessage" | "gmailLabel" | "rule" | "scheduledAction"
  targetId       String   // gmailMessageId / labelName / ruleId / etc
  // The actual tool invocation. Tool name is namespaced ("inbox.apply",
  // "rules.create"). toolInputJson is the JSON-encoded args struct.
  toolName       String
  toolInputJson  String
  toolResultJson String?
  reasoning      String?
  // JSON-encoded inverse Action when one exists, or null. The reversal
  // endpoint re-runs that Action and writes a new AgentAction row.
  reversibleAs   String?
  reversedAt     DateTime?
  reversedBy     String?
  // Lifecycle: "pending" rows are pre-written before the underlying
  // mutation; on success they flip to "applied" with appliedAt set, on
  // failure to "failed" with errorMessage set. Crash between mutation
  // and flip leaves a "pending" row visible to the user, never a silent
  // mutation. Default "applied" so legacy callers stay backwards
  // compatible.
  status         String   @default("applied") // "pending" | "applied" | "failed"
  appliedAt      DateTime?
  errorMessage   String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, source, createdAt])
  @@index([userId, targetType, targetId])
  // Used by the reversal endpoint (find the audit row a chat reverse
  // points back at) and by scheduler dedup (forward already happened?).
  @@index([userId, sourceId])
}

// Authoritative local mirror of every Gmail filter we've ever seen for this
// user. The UI renders one row per record with an Enabled toggle:
//   - enabled = true  → filter is present in Gmail (currentGmailId set)
//   - enabled = false → filter was removed from Gmail but we still hold the
//                        definition and can re-create it on demand.
// This model replaces the snapshot-blob FilterBackup (kept for back-compat).
model GmailFilter {
  id              String   @id @default(cuid())
  userId          String
  // Latest ID assigned by Gmail; null when disabled (not currently in Gmail).
  currentGmailId  String?
  // The Gmail filter's criteria + action, stored as JSON so we can re-create
  // verbatim. Label name map snapshotted at sync time so a rename in Gmail
  // doesn't orphan us.
  criteriaJson    String
  actionJson      String
  labelMap        String   @default("{}") // { "Label_123": "my label" }
  // Optional Claude-translated description, surfaced in the UI for readability.
  naturalLanguage String?
  enabled         Boolean  @default(true)
  // Monotonic signature of (criteria+action). Used to dedupe when the user
  // has the same filter in Gmail twice, or when sync sees a pre-existing one.
  signature       String
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // No unique(userId, signature) — sync should be able to coexist with a
  // disabled backup of the same criteria. Disabled rows are immutable
  // archives; enabled rows are the live mirror of Gmail.
  @@index([userId, signature])
  @@index([userId, enabled])
}

// Local mirror of the user's Gmail inbox. We resync before every run so
// classification reads message bodies from SQLite instead of fetching each
// one from Gmail — which is the slow + serial part of a classify loop.
// On sync we fetch only messages not already cached and drop rows for
// messages that have left the inbox (archived/trashed in Gmail).
model InboxMessage {
  id             String    @id @default(cuid())
  userId         String
  gmailMessageId String
  threadId       String?
  historyId      String?
  fromHeader     String?
  toHeader       String?
  subject        String?
  snippet        String?
  bodyText       String?
  labelIds       String    @default("[]") // JSON-encoded string[]
  dateHeader     String?
  internalDate   DateTime?
  // Mailing-list awareness. Captured at sync time from the message
  // headers (List-Id, Reply-To, Sender, Precedence, Mailing-list,
  // X-Original-From). When the email arrived via a mailing list /
  // Google Group / etc., the visible `fromHeader` is often rewritten
  // (e.g. "'Apple' via Zeligs <list@…>") and the real sender lives in
  // `originalFromHeader`. The proposer + classifier are passed both,
  // and prefer the `list:` Gmail operator when matching list mail.
  // Bare List-ID value, with surrounding `<>` stripped. e.g. "zelig.zelig.me".
  listId               String?
  // Mailto address that List-Post points at, if present.
  listPost             String?
  // First mailto / URL in List-Unsubscribe, if present.
  listUnsubscribe      String?
  // Real sender behind a list rewrite — pulled from Reply-To / Sender
  // / X-Original-From / X-Google-Original-From when those disagree
  // with the visible From. Null when From is already the original.
  originalFromHeader   String?
  // Precedence header: 'list' / 'bulk' / 'junk' / etc.
  precedence           String?
  fetchedAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
  @@index([userId, internalDate])
  @@index([userId, listId])
}

// Local embedding vectors for the user's inbox. Powers
// inbox.semanticSearch + inbox.similar MCP tools used by the searcher
// specialist. One row per InboxMessage; we re-embed when contentHash
// changes (subject/snippet/body diff).
model MessageEmbedding {
  id             String   @id @default(cuid())
  userId         String
  gmailMessageId String
  // f32 vector serialised; default model dim is 384 (MiniLM-L6-v2).
  embedding      Bytes
  // sha256 of the encoded text — lets the indexer skip work on unchanged rows.
  contentHash    String
  // Guard against stale embeddings if we swap models later.
  modelVersion   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
  @@index([userId, modelVersion])
}

model ClassifyRun {
  id         String    @id @default(cuid())
  userId     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  trigger    String    // manual | poll | schedule
  status     String    @default("running") // running | done | error
  ruleIds    String? // JSON array of rule ids or null for all
  scanned    Int       @default(0)
  matched    Int       @default(0)
  applied    Int       @default(0)
  scheduled  Int       @default(0)
  skipped    Int       @default(0)
  logJson    String    @default("[]") // JSON array of {t, level, msg}
  errorMsg   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model Rule {
  id                  String   @id @default(cuid())
  userId              String
  naturalLanguage     String
  actionsJson         String   // JSON-encoded Action[]
  originalFilterJson  String?  // JSON-encoded gmail filter
  position            Int      @default(0)
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledActions ScheduledAction[]

  @@index([userId, position])
}

model FilterBackup {
  id           String   @id @default(cuid())
  userId       String
  snapshotJson String   // JSON-encoded snapshot
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EmailDecision {
  id               String   @id @default(cuid())
  userId           String
  gmailMessageId   String
  matchedRuleIds   String   // JSON-encoded string[]
  reasoning        String   // JSON-encoded {ruleId, reasoning}[]
  actionsApplied   String   // JSON-encoded
  actionsScheduled String   // JSON-encoded
  modelVersion     String
  // Gmail's message historyId at the moment we classified. Bumping this
  // (labels changed, moved, etc.) invalidates the cache for this message.
  contentHistoryId String?
  createdAt        DateTime @default(now())
  // Updates on every upsert — compared against max(Rule.updatedAt) so a
  // rule edit invalidates every stale decision for the user.
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
  @@index([userId, createdAt])
}

model ScheduledAction {
  id             String   @id @default(cuid())
  userId         String
  ruleId         String
  gmailMessageId String
  action         String   // JSON-encoded Action
  runAt          DateTime
  status         String   @default("pending") // pending | running | done | cancelled | failed | skipped | stale
  reasoning      String?
  attempts       Int      @default(0)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([status, runAt])
  @@index([userId, status])
  @@index([ruleId])
}

model ForwardingAddress {
  id        String   @id @default(cuid())
  userId    String
  address   String
  verified  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
}
